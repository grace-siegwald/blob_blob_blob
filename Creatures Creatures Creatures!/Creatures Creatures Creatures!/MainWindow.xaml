<Window x:Class="Creatures_Creatures_Creatures_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Creatures_Creatures_Creatures_"
        mc:Ignorable="d"
        Title="Blob Blob Blob" Height="550" Width="450">
    <Grid Loaded="Grid_Loaded">                                                                               
        <Canvas x:Name="GameCanvas" Background="AliceBlue" MouseLeftButtonDown="GameCanvas_Click"/>
        <TextBlock x:Name="RoundCounter" HorizontalAlignment="Left" Margin="338,65,0,0" TextWrapping="Wrap" Text="Round 1" VerticalAlignment="Top" FontSize="20"/>
        <TextBlock x:Name="HealthCounter" HorizontalAlignment="Left" Margin="356,110,0,0" TextWrapping="Wrap" Text="Health = 3" VerticalAlignment="Top"/>
        <Button x:Name="StartButton" Content="Start Game!" HorizontalAlignment="Center" VerticalAlignment="Center" Height="50" Width="98" Click="StartButton_Click"/>
    </Grid>
</Window>
    