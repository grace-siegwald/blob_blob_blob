<Window x:Class="Creatures_Creatures_Creatures_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Creatures_Creatures_Creatures_"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Loaded="Grid_Loaded">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="55,38,345,37">
            <TextBlock x:Name="CreatureInfo" TextWrapping="Wrap" Text="TextBlock"/>
        </ScrollViewer>
        <TextBlock x:Name="CreatureAbilities" HorizontalAlignment="Left" Margin="519,0,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Center" Height="200" Width="250"/>
        <Button x:Name="AbilitiesButton" Content="Use Abilities!" HorizontalAlignment="Left" Margin="553,336,0,0" VerticalAlignment="Top" Height="35" Width="152" Click="AbilitiesButton_Click"/>
    </Grid>
</Window>
